# Database
DATABASE_URL=postgresql+asyncpg://jobai:jobai_secret@localhost:5432/jobai_db

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# OpenAI (optional — app works with mock if not set)
OPENAI_API_KEY=

# SendGrid (optional — falls back to console logging)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@jobai.local

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
